{
  "uid": "system-health-dashboard",
  "title": "System Health Dashboard",
  "description": "Monitors API throughput, latency, dependency health, component availability, and overall platform health.",
  "tags": ["platform", "sre", "gcp", "prometheus", "system-health-check-api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "targets": [{"expr": "sum(rate(api_requests_total[5m]))", "refId": "A", "legendFormat": "requests/s"}]
    },
    {
      "type": "stat",
      "title": "Total API Requests",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [{"expr": "api_requests_total", "refId": "A", "legendFormat": "total requests"}]
    },
    {
      "type": "timeseries",
      "title": "Average API Latency",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "seconds"}},
      "targets": [{"expr": "sum(rate(api_request_duration_seconds_sum[5m])) / sum(rate(api_request_duration_seconds_count[5m]))", "refId": "A", "legendFormat": "avg latency"}]
    },
    {
      "type": "timeseries",
      "title": "API P95 Latency",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "seconds"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))", "refId": "A", "legendFormat": "p95 latency"}]
    },
    {
      "type": "timeseries",
      "title": "Health Check Duration",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"unit": "seconds"}},
      "targets": [{"expr": "sum(rate(health_check_duration_seconds_sum[5m])) / sum(rate(health_check_duration_seconds_count[5m]))", "refId": "A", "legendFormat": "avg health check duration"}]
    },
    {
      "type": "stat",
      "title": "Total Health Checks",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [{"expr": "health_checks_total", "refId": "A", "legendFormat": "total health checks"}]
    },
    {
      "type": "stat",
      "title": "Healthy Components",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [{"expr": "sum(healthy_components)", "refId": "A", "legendFormat": "healthy components"}]
    },
    {
      "type": "stat",
      "title": "Unhealthy Components",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [{"expr": "sum(unhealthy_components)", "refId": "A", "legendFormat": "unhealthy components"}]
    },
    {
      "type": "stat",
      "title": "Current Dependency Failures",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [{"expr": "sum(unhealthy_components)", "refId": "A", "legendFormat": "dependency failures"}]
    },
    {
      "type": "stat",
      "title": "Current Error Ratio",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "targets": [{"expr": "sum(unhealthy_components) / clamp_min(sum(healthy_components) + sum(unhealthy_components), 1)", "refId": "A", "legendFormat": "error ratio"}]
    }
  ]
}
